// ============================================================
// 공정위 가맹정보시스템 - 전체 업종 자동 스크래핑 (전달용)
// ============================================================
// 대상: 13개 업종 (피자~세탁)
// 출처: franchise.ftc.go.kr 정보공개서 Section IV
// ============================================================
//
// ★ 실행 방법:
//   1. https://franchise.ftc.go.kr/mnu/00013/program/userRqst/list.do 접속
//   2. 아무 업종 선택 후 [검색] 클릭
//   3. F12 → Console → 이 스크립트 전체 붙여넣기 → Enter
//
// ★ 이어서 하기:
//   window._resumeIndustry = 2;  // 업종 인덱스 (아래 표 참조)
//   window._resumeBrand = 50;    // 브랜드 인덱스
//   // 스크립트 다시 붙여넣기
//
// ★ 업종 인덱스:
//   0=피자 1=치킨 2=한식 3=분식 4=커피 5=아이스크림
//   6=제과제빵 7=주점 8=편의점 9=기타도소매 10=이미용
//   11=PC방 12=세탁
//
// ★ 피자는 완료됨. 치킨부터 시작하려면:
//   window._resumeIndustry = 1;
//   // 스크립트 붙여넣기
//
// ★ 절전 모드 반드시 끄기! (절전 시 중단됨)
// ★ 예상 소요: 브랜드당 ~15초 × ~3,500개 = 약 15~18시간
// ============================================================

(async function() {
    const INDUSTRIES = [
        { upjong: '21', indus: 'I1', name: 'pizza',       label: '피자' },
        { upjong: '21', indus: 'H1', name: 'chicken',     label: '치킨' },
        { upjong: '21', indus: 'A1', name: 'korean',      label: '한식' },
        { upjong: '21', indus: 'B1', name: 'bunsik',      label: '분식' },
        { upjong: '21', indus: 'L1', name: 'cafe',        label: '커피' },
        { upjong: '21', indus: 'K1', name: 'icecream',    label: '아이스크림/빙수' },
        { upjong: '21', indus: 'J1', name: 'bakery',      label: '제과제빵' },
        { upjong: '21', indus: 'N1', name: 'pub',         label: '주점' },
        { upjong: '22', indus: 'A2', name: 'convenience',  label: '편의점' },
        { upjong: '22', indus: 'G2', name: 'retail_etc',  label: '기타도소매' },
        { upjong: '23', indus: 'I3', name: 'beauty',      label: '이미용' },
        { upjong: '23', indus: 'K3', name: 'pcroom',      label: 'PC방' },
        { upjong: '23', indus: 'O3', name: 'laundry',     label: '세탁' },
    ];

    const MIN_DELAY = 8000;
    const MAX_DELAY = 12000;
    const BLOCK_WAIT = 60000;
    const INDUSTRY_COOLDOWN = 60000;
    const MAX_CONSECUTIVE_BLOCKS = 3;
    const BATCH_SIZE = 20;

    const RESUME_INDUSTRY = window._resumeIndustry || 0;
    const RESUME_BRAND = window._resumeBrand || 0;
    const allResults = window._ftcAllResults || {};

    function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
    function randDelay() { return MIN_DELAY + Math.random() * (MAX_DELAY - MIN_DELAY); }

    // 차단/CAPTCHA 감지 시: 장시간 대기 후 자동 재시도
    const BLOCK_WAITS = [15*60*1000, 20*60*1000, 30*60*1000, 45*60*1000, 60*60*1000]; // 15분→20분→30분→45분→60분
    async function waitForUnblock() {
        for (let wi = 0; wi < BLOCK_WAITS.length; wi++) {
            const waitMin = Math.round(BLOCK_WAITS[wi] / 60000);
            console.log(`\n🔒 차단 감지! ${waitMin}분 대기 후 자동 재시도 (${wi+1}/${BLOCK_WAITS.length})...`);
            await sleep(BLOCK_WAITS[wi]);
            try {
                const testResp = await fetch('/mnu/00013/program/userRqst/list.do?selUpjong=21&pageUnit=10&pageIndex=1');
                const testHtml = await testResp.text();
                if (testHtml.length > 50000) {
                    console.log('✅ 차단 해제! 스크래핑 재개합니다.\n');
                    return true;
                }
                console.log('⏳ 아직 차단 중...');
            } catch(e) {
                console.log('⏳ 연결 오류...');
            }
        }
        console.log('🛑 장시간 차단 지속. 결과 저장 후 중단합니다.');
        return false;
    }

    function extractTd(html) {
        const re = /<td[^>]*>([\s\S]*?)<\/td>/gi;
        const vals = []; let m;
        while ((m = re.exec(html)) !== null) {
            vals.push(m[1].replace(/<[^>]*>/g, '').replace(/&nbsp;/g, '').replace(/\s+/g, ' ').trim());
        }
        return vals;
    }
    function clean(s) { return s.replace(/,/g, '').replace(/\s/g, '').trim(); }

    function parseBurden(html, row) {
        let s = html.indexOf('<!-- 가맹점사업자의 부담금 : S -->');
        let e = html.indexOf('<!-- 가맹점사업자의 부담금 : E -->');
        if (s !== -1 && e !== -1) {
            const vals = extractTd(html.substring(s, e));
            if (vals.length >= 5) { row.franchiseFee=clean(vals[0]); row.educationFee=clean(vals[1]); row.deposit=clean(vals[2]); row.otherCost=clean(vals[3]); row.totalInitCost=clean(vals[4]); return; }
        }
        s = html.indexOf('가맹점사업자의 부담금에 대한 표');
        if (s !== -1) { e = html.indexOf('</table>', s); if (e !== -1) {
            const vals = extractTd(html.substring(s, e));
            if (vals.length >= 5) { row.franchiseFee=clean(vals[0]); row.educationFee=clean(vals[1]); row.deposit=clean(vals[2]); row.otherCost=clean(vals[3]); row.totalInitCost=clean(vals[4]); return; }
        }}
        s = html.indexOf('가입비');
        if (s !== -1) { const tbody=html.indexOf('<tbody>',s); e=html.indexOf('</tbody>',tbody); if (tbody!==-1&&e!==-1) {
            const vals = extractTd(html.substring(tbody, e));
            if (vals.length >= 5) { row.franchiseFee=clean(vals[0]); row.educationFee=clean(vals[1]); row.deposit=clean(vals[2]); row.otherCost=clean(vals[3]); row.totalInitCost=clean(vals[4]); }
        }}
    }

    function parseInterior(html, row) {
        let s = html.indexOf('<!-- 인테리어 비용 : S -->');
        let e = html.indexOf('<!-- 인테리어 비용 : E -->');
        if (s !== -1 && e !== -1) {
            const vals = extractTd(html.substring(s, e));
            if (vals.length >= 3) { row.interiorPerUnit=clean(vals[0]); row.standardArea=clean(vals[1]); row.interiorCost=clean(vals[2]); return; }
        }
        s = html.indexOf('인테리어 비용에 대한 표');
        if (s !== -1) { e = html.indexOf('</table>', s); if (e !== -1) {
            const vals = extractTd(html.substring(s, e));
            if (vals.length >= 3) { row.interiorPerUnit=clean(vals[0]); row.standardArea=clean(vals[1]); row.interiorCost=clean(vals[2]); return; }
        }}
        s = html.indexOf('단위면적');
        if (s !== -1) { const tbody=html.indexOf('<tbody>',s); e=html.indexOf('</tbody>',tbody); if (tbody!==-1&&e!==-1) {
            const vals = extractTd(html.substring(tbody, e));
            if (vals.length >= 3) { row.interiorPerUnit=clean(vals[0]); row.standardArea=clean(vals[1]); row.interiorCost=clean(vals[2]); }
        }}
    }

    function parseDepositFee(html, row) {
        // "예치 가맹금" 이 <th> 안에 있는 실제 데이터 행을 찾기
        // 설명 텍스트("~포함되어 있습니다")가 먼저 매칭되는 것을 방지
        const thPattern = /<th[^>]*>[^<]*예치\s*가맹금[^<]*<\/th>\s*<td[^>]*>([\s\S]*?)<\/td>/i;
        const thMatch = html.match(thPattern);
        if (thMatch) {
            row.depositFranchiseFee = clean(thMatch[1].replace(/<[^>]*>/g, '').replace(/&nbsp;/g, ''));
        }
        // 형태 (예치제/가맹금대출 등)
        const typePattern = /<th[^>]*>[^<]*형태[^<]*<\/th>\s*<td[^>]*>([\s\S]*?)<\/td>/i;
        const typeMatch = html.match(typePattern);
        if (typeMatch) {
            row.depositType = typeMatch[1].replace(/<[^>]*>/g, '').replace(/&nbsp;/g, '').trim();
        }
    }

    function parseOpCost(html, row) {
        const s4 = html.indexOf('가맹점사업자의 부담');
        if (s4 === -1) return;
        const s5 = html.indexOf('영업활동에 대한 조건', s4);
        const section = html.substring(s4, s5 !== -1 ? s5 : s4 + 50000);
        const ri = section.indexOf('로열티');
        if (ri !== -1) { const m = section.substring(ri, ri+500).match(/[\d,]+\s*(?:천원|만원|원|%)/); if (m) row.royalty = m[0].trim(); }
        const ai = section.indexOf('광고');
        if (ai !== -1) { const m = section.substring(ai, ai+500).match(/[\d,]+\s*(?:천원|만원|원|%)/); if (m) row.adFee = m[0].trim(); }
    }

    function downloadCSV(data, filename) {
        const h = ['No','브랜드명','상호명','firMstSn','가입비_가맹비','교육비','보증금','기타비용','합계','인테리어_3.3m2당','기준점포면적_m2','인테리어비용','로열티','광고분담금','예치형태','예치가맹금','에러'].join('\t');
        const rows = data.map(r=>[r.no,r.brandNm,r.companyNm,r.firMstSn,r.franchiseFee,r.educationFee,r.deposit,r.otherCost,r.totalInitCost,r.interiorPerUnit,r.standardArea,r.interiorCost,r.royalty,r.adFee,r.depositType,r.depositFranchiseFee,r.error].join('\t')).join('\n');
        const blob = new Blob(['\ufeff'+h+'\n'+rows], {type:'text/csv;charset=utf-8'});
        const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=filename; a.click();
    }

    function downloadJSON(data, filename) {
        const blob = new Blob([JSON.stringify(data,null,2)], {type:'application/json;charset=utf-8'});
        const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=filename; a.click();
    }

    function downloadAllJSON(data) {
        const blob = new Blob([JSON.stringify(data,null,2)], {type:'application/json;charset=utf-8'});
        const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='ftc_all_industries.json'; a.click();
    }

    // ========== 메인 루프 ==========
    console.log('╔══════════════════════════════════════════╗');
    console.log('║  공정위 전체 업종 자동 스크래핑 시작       ║');
    console.log('╚══════════════════════════════════════════╝');
    console.log(`업종 ${INDUSTRIES.length}개: ${INDUSTRIES.map(i=>i.label).join(', ')}`);
    console.log(`시작: 업종[${RESUME_INDUSTRY}] ${INDUSTRIES[RESUME_INDUSTRY].label}, 브랜드 ${RESUME_BRAND}번째부터\n`);

    for (let indIdx = RESUME_INDUSTRY; indIdx < INDUSTRIES.length; indIdx++) {
        const ind = INDUSTRIES[indIdx];
        const startFrom = (indIdx === RESUME_INDUSTRY) ? RESUME_BRAND : 0;

        console.log(`\n${'='.repeat(60)}`);
        console.log(`[업종 ${indIdx+1}/${INDUSTRIES.length}] ${ind.label} (${ind.upjong}-${ind.indus})`);
        console.log(`${'='.repeat(60)}`);

        // ---- 브랜드 목록 수집 ----
        let rawBrands = [];
        let pageIndex = 1;
        let totalPages = 1;

        while (pageIndex <= totalPages) {
            console.log(`  목록 페이지 ${pageIndex}...`);
            const formData = new URLSearchParams({
                selUpjong: ind.upjong, selIndus: ind.indus,
                pageUnit: '300', pageIndex: String(pageIndex)
            });
            const resp = await fetch('/mnu/00013/program/userRqst/list.do', {
                method: 'POST',
                headers: {'Content-Type': 'application/x-www-form-urlencoded'},
                body: formData
            });
            const listHtml = await resp.text();

            if (pageIndex === 1) {
                const totalMatch = listHtml.match(/총\s*(\d+)\s*건/);
                if (totalMatch) {
                    const total = parseInt(totalMatch[1]);
                    totalPages = Math.ceil(total / 300);
                    console.log(`  총 ${total}건, ${totalPages} 페이지`);
                }
            }

            const rowRegex = /<tr[^>]*>([\s\S]*?)<\/tr>/gi;
            let rowMatch;
            while ((rowMatch = rowRegex.exec(listHtml)) !== null) {
                const rowHtml = rowMatch[1];
                const linkRegex = /fn_moveUrl\('\/mnu\/00013\/program\/userRqst\/view\.do\?encFirMstSn=',\s*'([^']+)'\)">([^<]+)<\/a>/g;
                const links = [];
                let linkMatch;
                while ((linkMatch = linkRegex.exec(rowHtml)) !== null) {
                    links.push({ encFirMstSn: linkMatch[1], name: linkMatch[2].trim() });
                }
                if (links.length >= 2) {
                    rawBrands.push({
                        encFirMstSn: links[0].encFirMstSn,
                        companyNm: links[0].name,
                        brandNm: links[1].name
                    });
                }
            }
            pageIndex++;
            if (pageIndex <= totalPages) await sleep(3000);
        }

        // 중복 제거
        const seen = new Set();
        const allBrands = rawBrands.filter(b => {
            if (seen.has(b.encFirMstSn)) return false;
            seen.add(b.encFirMstSn);
            return true;
        });

        console.log(`  ${rawBrands.length}행 → ${allBrands.length}개 브랜드 (시작: ${startFrom})`);

        // ---- 비용 데이터 추출 ----
        const results = allResults[ind.name] || [];
        let consecutiveBlocks = 0;

        for (let i = startFrom; i < allBrands.length; i++) {
            const brand = allBrands[i];
            console.log(`  [${ind.label} ${i+1}/${allBrands.length}] ${brand.brandNm}...`);

            const row = {
                no: i + 1, brandNm: brand.brandNm, companyNm: brand.companyNm,
                encFirMstSn: brand.encFirMstSn, firMstSn: '',
                franchiseFee: '', educationFee: '', deposit: '',
                otherCost: '', totalInitCost: '',
                interiorPerUnit: '', standardArea: '', interiorCost: '',
                royalty: '', adFee: '', depositType: '', depositFranchiseFee: '', error: ''
            };

            for (let attempt = 0; attempt < 2; attempt++) {
                try {
                    const resp = await fetch('/mnu/00013/program/userRqst/view.do?encFirMstSn=' + encodeURIComponent(brand.encFirMstSn));

                    if (!resp.ok) {
                        const unblocked = await waitForUnblock();
                        if (!unblocked) {
                            row.error = 'HTTP ' + resp.status;
                            downloadCSV(results, 'ftc_' + ind.name + '_stopped_at_' + (i+1) + '.csv');
                            downloadJSON(results, 'ftc_' + ind.name + '_stopped_at_' + (i+1) + '.json');
                            downloadAllJSON(allResults);
                            console.log(`이어서: window._resumeIndustry=${indIdx}; window._resumeBrand=${i};`);
                            return;
                        }
                        consecutiveBlocks = 0;
                        continue;
                    }

                    const html = await resp.text();

                    if (html.length < 50000) {
                        const unblocked = await waitForUnblock();
                        if (!unblocked) {
                            row.error = '장시간차단';
                            downloadCSV(results, 'ftc_' + ind.name + '_stopped_at_' + (i+1) + '.csv');
                            downloadJSON(results, 'ftc_' + ind.name + '_stopped_at_' + (i+1) + '.json');
                            downloadAllJSON(allResults);
                            console.log(`이어서: window._resumeIndustry=${indIdx}; window._resumeBrand=${i};`);
                            return;
                        }
                        consecutiveBlocks = 0;
                        continue;
                    }

                    consecutiveBlocks = 0;
                    const firMatch = html.match(/name="firMstSn"[^>]*value="(\d+)"/);
                    if (firMatch) row.firMstSn = firMatch[1];

                    parseBurden(html, row);
                    parseInterior(html, row);
                    parseDepositFee(html, row);
                    parseOpCost(html, row);
                    row.error = '';

                    console.log(`    ✓ 가맹비=${row.franchiseFee} 교육비=${row.educationFee} 보증금=${row.deposit} 기타=${row.otherCost} 합계=${row.totalInitCost} 인테리어/3.3=${row.interiorPerUnit} 면적=${row.standardArea} 인테리어=${row.interiorCost} 예치=${row.depositFranchiseFee} 로열티=${row.royalty} 광고=${row.adFee}`);
                    break;

                } catch (e) {
                    row.error = e.message;
                    consecutiveBlocks++;
                    if (attempt === 0) await sleep(BLOCK_WAIT);
                }
            }

            results.push(row);
            allResults[ind.name] = results;
            window._ftcAllResults = allResults;
            window._resumeIndustry = indIdx;
            window._resumeBrand = i + 1;

            // consecutiveBlocks는 waitForUnblock에서 처리됨

            if ((i + 1) % BATCH_SIZE === 0) {
                console.log(`    --- ${ind.label} ${i+1}/${allBrands.length} 중간 저장 ---`);
                downloadCSV(results, 'ftc_' + ind.name + '_batch_' + (i+1) + '.csv');
            }

            await sleep(randDelay());
        }

        console.log(`\n✅ ${ind.label} 완료! ${results.filter(r=>!r.error).length}/${results.length} 성공`);
        downloadCSV(results, 'ftc_' + ind.name + '_costs_final.csv');
        downloadJSON(results, 'ftc_' + ind.name + '_costs_final.json');

        if (indIdx < INDUSTRIES.length - 1) {
            console.log(`\n⏳ 다음 업종 전 ${INDUSTRY_COOLDOWN/1000}초 쿨다운...`);
            await sleep(INDUSTRY_COOLDOWN);
        }
    }

    console.log('\n╔══════════════════════════════════════════╗');
    console.log('║         전체 스크래핑 완료!                ║');
    console.log('╚══════════════════════════════════════════╝');

    for (const ind of INDUSTRIES) {
        const r = allResults[ind.name] || [];
        const ok = r.filter(x => !x.error).length;
        console.log(`  ${ind.label}: ${ok}/${r.length}`);
    }

    downloadAllJSON(allResults);
})();
